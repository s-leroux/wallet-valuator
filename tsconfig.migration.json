{
  "compilerOptions": {
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "resolveJsonModule": true,
    "sourceMap": true,
    "target": "es2024",
    "lib": ["es2024", "esnext"],
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noUnusedParameters": false,
    "declaration": true,
    "outDir": "build-migration"
  },
  "files": [
    "src/bignumber.mts",
    "src/price.mts",
    "src/cryptoasset.mts",
    "src/valuation.mts",
    "test/bignumber.spec.mts",
    "test/price.spec.mts",
    "test/cryptoasset.spec.mts",
    "test/valuation.spec.mts"
  ],
  "watchOptions": {
    "watchFile": "dynamicprioritypolling",
    "watchDirectory": "dynamicprioritypolling"
  }
}
